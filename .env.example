# ── Required ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your groq key   # free at console.groq.com
TAVILY_API_KEY=your tavily key  # free tier at app.tavily.com

# ── OpenAI (optional — only needed if you want OpenAI embeddings) ──────────────
OPENAI_API_KEY=your open api key
# ── Model (Groq free models) ───────────────────────────────────────────────────
# Options: llama-3.3-70b-versatile  |  llama-3.1-8b-instant  |  mixtral-8x7b-32768
OPENAI_MODEL=llama-3.3-70b-versatile

# ── Storage ────────────────────────────────────────────────────────────────────
SQLITE_PATH=data/sqlite/atlas.db
CHROMA_PATH=data/chroma
